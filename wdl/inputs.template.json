{
  "__comment__": "MANGO trio DMR workflow inputs. Simplest setup: provide the 3 BAMs (+indexes), set assembly=hg38, pick a mode, and set docker. Leave reference_fasta/fai/gtf/cpg_islands OUT to auto-download the reference. In a Terra workspace you can bind File fields to a Data Table (e.g. \"this.aligned_nanopore_file\").",

  "mango_trio.proband_bam": "gs://your-workspace-bucket/proband.bam",
  "mango_trio.proband_bai": "gs://your-workspace-bucket/proband.bam.bai",
  "mango_trio.proband_label": "proband",
  "mango_trio.proband_sex": "F",
  "mango_trio.proband_affection": "affected",

  "mango_trio.relative1_bam": "gs://your-workspace-bucket/mother.bam",
  "mango_trio.relative1_bai": "gs://your-workspace-bucket/mother.bam.bai",
  "mango_trio.relative1_label": "mother",
  "mango_trio.relative1_sex": "F",
  "mango_trio.relative1_relationship": "mother",
  "mango_trio.relative1_affection": "unaffected",

  "mango_trio.relative2_bam": "gs://your-workspace-bucket/father.bam",
  "mango_trio.relative2_bai": "gs://your-workspace-bucket/father.bam.bai",
  "mango_trio.relative2_label": "father",
  "mango_trio.relative2_sex": "M",
  "mango_trio.relative2_relationship": "father",
  "mango_trio.relative2_affection": "unaffected",

  "__reference_comment__": "Auto-download: just set assembly. To use your own reference instead, add mango_trio.reference_fasta + mango_trio.reference_fai (+ mango_trio.gtf for targeted mode) with gs:// paths, which then override the download.",
  "mango_trio.assembly": "hg38",

  "mango_trio.mode": "targeted",
  "mango_trio.chromosomes": [],
  "mango_trio.genes": ["MECP2", "UBE3A", "SNRPN"],

  "mango_trio.modified_bases": ["5mC"],
  "mango_trio.combine_strands": true,
  "mango_trio.threshold_overrides": ["min_sites=5", "alpha=0.05"],

  "mango_trio.docker": "ghcr.io/shaybehesht/mango:latest",
  "mango_trio.cpu": 4,
  "mango_trio.memory_gb": 16,
  "mango_trio.disk_gb": 100,
  "mango_trio.preemptible": 1
}
